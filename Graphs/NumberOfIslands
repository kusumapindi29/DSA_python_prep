
"""
Problem: Number of Islands
Pattern: Graph DFS
Platform: LeetCode
Link: https://leetcode.com/problems/number-of-islands/

Approach:
Use DFS to explore connected land cells ('1'). 
Whenever we encounter an unvisited land cell, we start a DFS and mark all
connected land cells (up, down, left, right) as visited. Each DFS call
represents one island.

Time Complexity: O(m * n)  -  Each cell in the grid is visited at most once during DFS traversal.
Space Complexity: O(m * n)
"""
class Solution:
    def numIslands(self, grid: List[List[str]]) -> int:
        visited=set()
        m=len(grid)
        n=len(grid[0])
        nums=0
        def dfs(i,j):
            if (i,j) not in visited:
                visited.add((i,j))
            if j+1<n and grid[i][j+1]=='1':
                if (i,j+1) not in visited:
                    dfs(i,j+1)
            if j-1>=0 and grid[i][j-1]=='1':
                if (i,j-1) not in visited:
                    dfs(i,j-1)
            if i+1<m and grid[i+1][j]=='1':
                if (i+1,j) not in visited:
                    dfs(i+1,j)
            if i-1>=0 and grid[i-1][j]=='1':
                if (i-1,j) not in visited:
                    dfs(i-1,j)
        for i in range(0,m):
            for j in range(0,n):
                if grid[i][j]=='1':
                    if (i,j) not in visited:
                        dfs(i,j)
                        nums+=1             
        return nums
